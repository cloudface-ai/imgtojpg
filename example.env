# Email Configuration Example
# Copy this file to .env and fill in your actual credentials

# Gmail Email Configuration (sample)
# 1) Turn on 2‑Step Verification for your Google account
# 2) Create an App Password for “Mail” → “Other (Custom)”
# 3) Paste the 16‑character app password below (no spaces)
# Do NOT commit your real .env to git.

# Email Configuration Example
# Copy this file to .env and fill in your actual credentials

# Gmail Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=

# Admin Security Token
# Generate a secure random token for admin access
# IMPORTANT: Change this to a secure random string in production!
ADMIN_TOKEN=your-secure-admin-token-here

